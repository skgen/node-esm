{
    "compilerOptions": {
        "target": "es2019",
        "module": "es2020",
        "moduleResolution": "node16",
        "strict": true,
        "noEmit": true,
        "forceConsistentCasingInFileNames": true,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "removeComments": true,
        "preserveConstEnums": true,
        "isolatedModules": true,
        "outDir": "./dist",
        "types": [
            "node"
        ],
        "typeRoots": [
            "./node_modules/@types"
        ],
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ]
        }
    },
    "include": [
        "./src/**/*.ts",
    ],
    "exclude": [
        "./node_modules",
    ]
}